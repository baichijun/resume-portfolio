#!/bin/sh
# .cursor/plans 仅本地版本化，禁止推送到 GitHub / Local-only plans; block remote push
zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')

while read -r local_ref local_oid remote_ref remote_oid; do
  [ "$local_oid" = "$zero" ] && continue

  if [ "$remote_oid" = "$zero" ]; then
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  if git diff-tree --no-commit-id --name-only -r "$range" 2>/dev/null | grep -qE '^\.cursor/plans/.*\.plan\.md$'; then
    echo "error: .cursor/plans/*.plan.md is local-only. Remove plan files from commits before pushing."
    exit 1
  fi
done

exit 0
