#!/bin/sh
# Block push of .cursor/plans/*.plan.md / 禁止推送 Plan 文件到 GitHub
zero=0000000000000000000000000000000000000000

while read -r local_ref local_oid remote_ref remote_oid; do
  [ "$local_oid" = "$zero" ] && continue

  if [ "$remote_oid" = "$zero" ]; then
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  if git log --format= --name-only "$range" | grep '.cursor/plans/' | grep -q '.plan.md'; then
    echo "error: .cursor/plans/*.plan.md is local-only and must not be pushed to GitHub."
    exit 1
  fi
done

exit 0
